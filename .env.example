# Server Configuration
HOST=0.0.0.0
PORT=8000

# Optional: Hugging Face Hub (higher rate limits, faster first-time model download).
# Create a read token at https://huggingface.co/settings/tokens
# Required for `docker compose` to pass the token: use project `.env` (see docker-compose.yml).
# HF_TOKEN=hf_...

# TTS Configuration
MAX_SENTENCES_PER_CHUNK=3
MAX_CHUNK_CHARS=320
CHUNK_GAP_MS=120

# Device: auto, cuda, mps, or cpu
DEVICE=auto

# CPU thread budget for inference (0 = all logical CPUs; set e.g. 4 to cap). Also sets OMP/MKL.
# On Docker Desktop, give the VM more CPUs under Settings > Resources.
TORCH_NUM_THREADS=0

# Default voice name (must exist in voices/ directory)
DEFAULT_VOICE=dan

# Output format: mp3 or wav
DEFAULT_OUTPUT_FORMAT=mp3

# Database
DATABASE_PATH=data/jobs.db

# Worker settings
WORKER_POLL_INTERVAL=2
MAX_CHAPTER_RETRIES=3
